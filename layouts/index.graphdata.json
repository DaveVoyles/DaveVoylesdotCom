{{- $.Scratch.Add "nodes" slice -}}

{{- /* Only real posts (Type "posts") count as graph nodes -- an allowlist,
       not a denylist of known special pages by layout name, so a future
       root-level page (About, etc.) can never leak in as a spurious
       self-referential node the way /graph/ itself did before this fix. */ -}}
{{- $pages := where site.RegularPages "Type" "posts" -}}

{{- range $pages -}}
    {{- $.Scratch.Add "nodes" (dict "id" .RelPermalink "title" .Title "permalink" .Permalink "topic" (index (.Params.topics | default slice) 0 | default "") "type" "post") -}}
{{- end -}}

{{- /* Vault notes as a visually distinct node type (plan 0004 / D7):
       "type": "vault" (new field, additive on post nodes too, above)
       drives the frontend's node-coloring logic in layouts/graph.html.
       No "topic" value -- vault notes use a separate vaultTopics
       taxonomy (D4), not the posts-only topics taxonomy this graph's
       existing tag/topic edge logic below is built around, and the
       empty-topic case already renders/filters correctly (graph.html's
       filter treats topic:"" nodes as always-visible). */ -}}
{{- $vaultPages := where site.RegularPages "Section" "vault" -}}
{{- range $vaultPages -}}
    {{- $.Scratch.Add "nodes" (dict "id" .RelPermalink "title" .Title "permalink" .Permalink "topic" "" "type" "vault") -}}
{{- end -}}

{{- /* Research-backed hairball fixes (docs/research/graph-view-ux-patterns.md,
       R1/R2): "Uncategorized" is a placeholder with no topical signal and is
       excluded outright; "Game Dev"/"Programming" are generic legacy tags
       covering 46%/38% of all posts and act as universal connectors, so a
       shared occurrence of either counts as half a normal shared tag rather
       than a full one. An edge requires a combined weight of 2+ (not just
       any single shared tag), which directly targets the measured 42.5%
       edge density / hub-post problem. */ -}}
{{- $excludeTerms := slice "Uncategorized" -}}
{{- $downweightTerms := slice "Game Dev" "Game Development" "Programming" -}}
{{- $edgeThreshold := 2.0 -}}

{{- $.Scratch.Add "edges" slice -}}
{{- range $i, $page1 := $pages -}}
    {{- range $j, $page2 := $pages -}}
        {{- /* Only process pairs where i < j to avoid duplicates and self-edges */ -}}
        {{- if lt $i $j -}}
            {{- /* Combine tags and categories for both pages, dropping noise terms */ -}}
            {{- $tags1 := $page1.Params.tags | default slice -}}
            {{- $cats1 := $page1.Params.categories | default slice -}}
            {{- $combined1 := complement $excludeTerms (union $tags1 $cats1) -}}

            {{- $tags2 := $page2.Params.tags | default slice -}}
            {{- $cats2 := $page2.Params.categories | default slice -}}
            {{- $combined2 := complement $excludeTerms (union $tags2 $cats2) -}}

            {{- /* Find shared values between the two posts */ -}}
            {{- $shared := intersect $combined1 $combined2 -}}

            {{- /* Weight: generic/high-frequency terms count half as much as a genuine shared term */ -}}
            {{- $weight := 0.0 -}}
            {{- range $shared -}}
                {{- if in $downweightTerms . -}}
                    {{- $weight = add $weight 0.5 -}}
                {{- else -}}
                    {{- $weight = add $weight 1.0 -}}
                {{- end -}}
            {{- end -}}

            {{- /* Only create an edge once the combined weight clears the threshold */ -}}
            {{- if ge $weight $edgeThreshold -}}
                {{- $.Scratch.Add "edges" (dict "source" $page1.RelPermalink "target" $page2.RelPermalink "weight" $weight) -}}
            {{- end -}}
        {{- end -}}
    {{- end -}}
{{- end -}}

{{- /* Wikilink-derived edges (plan 0004 / D7, ADR 0009): sourced from D6's
       shared reverse-link index (same partialCached "wikilink-index"
       call, so this can never drift from what the Backlinks UI shows).
       Purely additive alongside the existing shared-tag/topic edges
       above -- doesn't touch that loop or its weighting logic, so the
       pre-existing post-to-post edge count is unaffected. "kind" tags
       these distinctly from tag/topic edges (which have no "kind"
       field) in case a future change wants to style them differently;
       "weight" is a flat 1.0 since wikilink edges have no natural
       shared-term count to weight by, unlike the tag/topic edges. */ -}}
{{- $wikilinkEdges := partialCached "wikilink-index.html" "wikilink-index" -}}
{{- range $wikilinkEdges -}}
    {{- $.Scratch.Add "edges" (dict "source" .source.RelPermalink "target" .target.RelPermalink "weight" 1.0 "kind" "wikilink") -}}
{{- end -}}

{{- /* Output final JSON */ -}}
{{- dict "nodes" ($.Scratch.Get "nodes") "edges" ($.Scratch.Get "edges") | jsonify -}}
